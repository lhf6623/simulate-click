{
  "name": "simulate-click",
  "version": "1.0.2",
  "description": "Mac鼠标模拟点击工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:swift": "swiftc bg_click.swift -o bg_click -framework CoreGraphics && swiftc check_perm.swift -o check_perm -framework CoreGraphics",
    "pack": "npm run build:swift && electron-builder --dir",
    "dist": "npm run build:swift && electron-builder"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "@jitsi/robotjs": "^0.6.22",
    "is-admin": "^2.0.0"
  },
  "build": {
    "appId": "com.example.simulate-click",
    "productName": "模拟点击",
    "mac": {
      "target": "dmg",
      "icon": "icon.icns",
      "hardenedRuntime": true,
      "entitlements": "entitlements.plist",
      "entitlementsInherit": "entitlements.plist",
      "extraResources": [
        { "from": "bg_click", "to": "." },
        { "from": "check_perm", "to": "." }
      ]
    }
  }
}
