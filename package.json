{
  "name": "simulate-click",
  "version": "1.0.0",
  "description": "Mac鼠标模拟点击工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "@jitsi/robotjs": "^0.6.22",
    "is-admin": "^2.0.0"
  },
  "build": {
    "appId": "com.example.simulate-click",
    "productName": "模拟点击",
    "mac": {
      "target": "dmg",
      "icon": "icon.icns",
      "hardenedRuntime": true,
      "entitlements": "entitlements.plist",
      "entitlementsInherit": "entitlements.plist"
    }
  }
}
